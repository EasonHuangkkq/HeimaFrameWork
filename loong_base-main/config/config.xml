<?xml version="1.0" encoding="UTF-8"?>
<!-- 15-motor lower-body config for Heima bring-up -->
<!-- Bus order: left leg (6) -> right leg (6) -> lumbar (3) -->
<Config>
    <ECAT>
        <Devices>
            <Device type="MT_Device">
                <VendorID>0x00202008</VendorID> 
                <ProductCode>0x00000000</ProductCode>

                <RxPDOs index="0x1600">
                    <Object>Controlword</Object>
                    <Object>TargetPosition</Object>
                    <Object>TargetVelocity</Object>
                    <Object>TargetTorque</Object>
                    <Object>MaxTorque</Object>     
                    <Object>Mode</Object>
                    <Object>RxPDOPadding</Object>
                </RxPDOs>

                <TxPDOs index="0x1a00">
                    <Object>StatusWord</Object>
                    <Object>ActualPosition</Object>
                    <Object>ActualVelocity</Object>
                    <Object>ActualTorque</Object>
                    <Object>ErrorCode</Object>
                    <Object>ModeDisplay</Object>
                    <Object>TxPDOPadding</Object>
                </TxPDOs>

                <Dictionary>
                    <!-- Alias left read-only to avoid SDO write failures on devices that do not accept alias download -->
                    <Object index="0x0000" subindex="0x00" signed="0" bit_length="0"  operation="1">Alias</Object>

                    <Object index="0x607a" subindex="0x00" signed="1" bit_length="32" operation="0">TargetPosition</Object>
                    <Object index="0x60ff" subindex="0x00" signed="1" bit_length="32" operation="0">TargetVelocity</Object>
                    <Object index="0x6071" subindex="0x00" signed="1" bit_length="16" operation="0">TargetTorque</Object>
                    <Object index="0x6040" subindex="0x00" signed="0" bit_length="16" operation="0">Controlword</Object>
                    <Object index="0x6072" subindex="0x00" signed="0" bit_length="16" operation="0">MaxTorque</Object>
                    <Object index="0x6060" subindex="0x00" signed="1" bit_length="8"  operation="0">Mode</Object>
                    <Object index="0x5ffe" subindex="0x00" signed="0" bit_length="8"  operation="0">RxPDOPadding</Object>

                    <Object index="0x6064" subindex="0x00" signed="1" bit_length="32" operation="1">ActualPosition</Object>
                    <Object index="0x606c" subindex="0x00" signed="1" bit_length="32" operation="1">ActualVelocity</Object>
                    <Object index="0x6077" subindex="0x00" signed="1" bit_length="16" operation="1">ActualTorque</Object>
                    <Object index="0x6041" subindex="0x00" signed="0" bit_length="16" operation="1">StatusWord</Object>
                    <Object index="0x603f" subindex="0x00" signed="0" bit_length="16" operation="1">ErrorCode</Object>
                    <Object index="0x6061" subindex="0x00" signed="1" bit_length="8"  operation="1">ModeDisplay</Object>
                    <Object index="0x5ffe" subindex="0x00" signed="0" bit_length="8"  operation="1">TxPDOPadding</Object>
                </Dictionary>
            </Device>
        </Devices>

        <Categories>
            <Category name="driver">
                <Type>MT_Device</Type>
            </Category>
        </Categories>

        <Masters>
            <Master order="0" dc="true" period="2000000"/>
        </Masters>

        <Domains>
            <!-- 15 domains for 15 motors -->
            <Domain master="0" order="0" division="1"/>
            <Domain master="0" order="1" division="1"/>
            <Domain master="0" order="2" division="1"/>
            <Domain master="0" order="3" division="1"/>
            <Domain master="0" order="4" division="1"/>
            <Domain master="0" order="5" division="1"/>
            <Domain master="0" order="6" division="1"/>
            <Domain master="0" order="7" division="1"/>
            <Domain master="0" order="8" division="1"/>
            <Domain master="0" order="9" division="1"/>
            <Domain master="0" order="10" division="1"/>
            <Domain master="0" order="11" division="1"/>
            <Domain master="0" order="12" division="1"/>
            <Domain master="0" order="13" division="1"/>
            <Domain master="0" order="14" division="1"/>
        </Domains>

        <Slaves>
            <!-- Left leg: alias 1-6 (bus indices 0-5) -->
            <Slave master="0" domain="0" alias="1" type="MT_Device">1</Slave>
            <Slave master="0" domain="1" alias="2" type="MT_Device">1</Slave>
            <Slave master="0" domain="2" alias="3" type="MT_Device">1</Slave>
            <Slave master="0" domain="3" alias="4" type="MT_Device">1</Slave>
            <Slave master="0" domain="4" alias="5" type="MT_Device">1</Slave>
            <Slave master="0" domain="5" alias="6" type="MT_Device">1</Slave>
            <!-- Right leg: alias 7-12 (bus indices 6-11) -->
            <Slave master="0" domain="6" alias="7" type="MT_Device">1</Slave>
            <Slave master="0" domain="7" alias="8" type="MT_Device">1</Slave>
            <Slave master="0" domain="8" alias="9" type="MT_Device">1</Slave>
            <Slave master="0" domain="9" alias="10" type="MT_Device">1</Slave>
            <Slave master="0" domain="10" alias="11" type="MT_Device">1</Slave>
            <Slave master="0" domain="11" alias="12" type="MT_Device">1</Slave>
            <!-- Lumbar: alias 13-15 (bus indices 12-14) -->
            <Slave master="0" domain="12" alias="13" type="MT_Device">1</Slave>
            <Slave master="0" domain="13" alias="14" type="MT_Device">1</Slave>
            <Slave master="0" domain="14" alias="15" type="MT_Device">1</Slave>
        </Slaves>
    </ECAT>

